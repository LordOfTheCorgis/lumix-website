---
import { siteConfig, navigation } from "../data/site";

const currentYear = new Date().getFullYear();
---

<footer class="border-t border-terminal-border bg-lumix-black">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid grid-cols-1 md:grid-cols-5 gap-8 lg:gap-12">
            <!-- Brand -->
            <div class="md:col-span-2">
                <div class="flex items-center gap-3 mb-4">
                    <img
                        src={siteConfig.logo}
                        alt="Lumix Solutions"
                        class="h-8 w-auto"
                    />
                    <span class="text-mono text-sm">
                        lumix<span class="text-lumix-red">_</span>solutions
                    </span>
                </div>
                <p class="text-lumix-gray text-sm max-w-md mb-6">
                    Infrastructure built by engineers. We provide reliable
                    compute, game hosting, voice servers, and enterprise-grade
                    DDoS protection.
                </p>
                <div class="text-mono text-xs text-lumix-gray">
                    <span class="text-lumix-red">$</span> uptime --sla 99.99%
                </div>
            </div>

            <!-- Navigation -->
            <div>
                <h4
                    class="text-mono text-xs text-lumix-gray-light uppercase tracking-wider mb-4"
                >
                    Navigation
                </h4>
                <ul class="space-y-3">
                    <li>
                        <a
                            href="/"
                            class="text-sm text-lumix-gray hover:text-lumix-red transition-colors"
                        >
                            Home
                        </a>
                    </li>
                    {
                        navigation.map((item) => (
                            <li>
                                <a
                                    href={item.href}
                                    class="text-sm text-lumix-gray hover:text-lumix-red transition-colors"
                                >
                                    {item.name}
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </div>

            <!-- Quick Links -->
            <div>
                <h4
                    class="text-mono text-xs text-lumix-gray-light uppercase tracking-wider mb-4"
                >
                    Quick Links
                </h4>
                <ul class="space-y-3">
                    <li>
                        <a
                            href={siteConfig.links.billing}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="text-sm text-lumix-gray hover:text-lumix-red transition-colors"
                        >
                            Billing Portal ↗
                        </a>
                    </li>
                    <li>
                        <a
                            href={siteConfig.links.panel}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="text-sm text-lumix-gray hover:text-lumix-red transition-colors"
                        >
                            Panel ↗
                        </a>
                    </li>
                    <li>
                        <a
                            href="/status"
                            class="text-sm text-lumix-gray hover:text-lumix-red transition-colors"
                        >
                            System Status
                        </a>
                    </li>
                    <li>
                        <a
                            href={`mailto:${siteConfig.contact.support}`}
                            class="text-sm text-lumix-gray hover:text-lumix-red transition-colors"
                        >
                            Support
                        </a>
                    </li>
                    <li>
                        <a
                            href="/changelog"
                            class="text-sm text-lumix-gray hover:text-lumix-red transition-colors"
                        >
                            Changelog
                        </a>
                    </li>
                </ul>
            </div>

            <!-- Legal -->
            <div>
                <h4
                    class="text-mono text-xs text-lumix-gray-light uppercase tracking-wider mb-4"
                >
                    Legal
                </h4>
                <ul class="space-y-3">
                    <li>
                        <a
                            href="/privacy"
                            class="text-sm text-lumix-gray hover:text-lumix-red transition-colors"
                        >
                            Privacy Policy
                        </a>
                    </li>
                    <li>
                        <a
                            href="/terms"
                            class="text-sm text-lumix-gray hover:text-lumix-red transition-colors"
                        >
                            Terms of Service
                        </a>
                    </li>
                    <li>
                        <a
                            href="/ccpa"
                            class="text-sm text-lumix-gray hover:text-lumix-red transition-colors"
                        >
                            CA Privacy Rights
                        </a>
                    </li>
                </ul>
            </div>
        </div>

        <!-- Bottom Bar -->
        <div class="mt-12 pt-8 border-t border-terminal-border">
            <div
                class="flex flex-col sm:flex-row justify-between items-center gap-4"
            >
                <div class="text-mono text-xs text-lumix-gray">
                    © {currentYear} Lumix Solutions LLC. All rights reserved.
                </div>
                <div class="flex items-center gap-6">
                    <a
                        href={siteConfig.links.instagram}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-lumix-gray hover:text-lumix-red transition-colors"
                        aria-label="Instagram"
                    >
                        <svg
                            class="w-5 h-5"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            stroke-width="1.8"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <rect x="3" y="3" width="18" height="18" rx="5" ry="5"></rect>
                            <circle cx="12" cy="12" r="4"></circle>
                            <circle cx="17.5" cy="6.5" r="1.2" fill="currentColor" stroke="none"></circle>
                        </svg>
                    </a>
                    <a
                        href={siteConfig.links.tiktok}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-lumix-gray hover:text-lumix-red transition-colors"
                        aria-label="TikTok"
                    >
                        <svg
                            class="w-5 h-5"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"
                            ></path>
                        </svg>
                    </a>
                    <a
                        href={siteConfig.links.youtube}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-lumix-gray hover:text-lumix-red transition-colors"
                        aria-label="YouTube"
                    >
                        <svg
                            class="w-5 h-5"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"
                            ></path>
                        </svg>
                    </a>
                    <a
                        href={siteConfig.links.twitter}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-lumix-gray hover:text-lumix-red transition-colors"
                        aria-label="X/Twitter"
                    >
                        <svg
                            class="w-5 h-5"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                d="M14.234 10.162 22.977 0h-2.072l-7.591 8.824L7.251 0H.258l9.168 13.343L.258 24H2.33l8.016-9.318L16.749 24h6.993zm-2.837 3.299-.929-1.329L3.076 1.56h3.182l5.965 8.532.929 1.329 7.754 11.09h-3.182z"
                            ></path>
                        </svg>
                    </a>


                    <a
                        href={siteConfig.links.discord}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-lumix-gray hover:text-lumix-red transition-colors"
                        aria-label="Discord"
                    >
                        <svg
                            class="w-5 h-5"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                d="M20.317 4.3698a19.7913 19.7913 0 0 0-4.8851-1.5152.0741.0741 0 0 0-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 0 0-.0785-.037 19.7363 19.7363 0 0 0-4.8852 1.515.0699.0699 0 0 0-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 0 0 .0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 0 0 .0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 0 0-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 0 1-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 0 1 .0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 0 1 .0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 0 1-.0066.1276 12.2986 12.2986 0 0 1-1.873.8914.0766.0766 0 0 0-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 0 0 .0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 0 0 .0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 0 0-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189Z"
                            ></path>
                        </svg>
                    </a>
                </div>
            </div>
        </div>
    </div>
</footer>
