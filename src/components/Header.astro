---
import { siteConfig, navigation, announcementBanner } from "../data/site";

const bannerEnabled = announcementBanner.enabled && announcementBanner.announcements?.length > 0;
---

<header
    class:list={[
        "fixed left-0 right-0 z-50 border-b border-terminal-border bg-lumix-black/95 backdrop-blur-sm",
        bannerEnabled ? "top-9" : "top-0"
    ]}
>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
            <!-- Logo -->
            <a href="/" class="flex items-center gap-3 group">
                <img
                    src={siteConfig.logo}
                    alt="Lumix Solutions"
                    class="h-8 w-auto"
                />
                <span
                    class="text-mono text-sm text-lumix-gray group-hover:text-lumix-white transition-colors hidden sm:block"
                >
                    lumix<span class="text-lumix-red">_</span>solutions
                </span>
            </a>

            <!-- Desktop Navigation -->
            <nav class="hidden md:flex items-center gap-1">
                {
                    navigation.map((item) => (
                        <a
                            href={item.href}
                            class="px-4 py-2 text-sm text-lumix-gray hover:text-lumix-white transition-colors"
                        >
                            {item.name}
                        </a>
                    ))
                }
                <div class="w-px h-6 bg-terminal-border mx-2"></div>
                <a
                    href={siteConfig.links.panel}
                    class="btn-primary text-sm"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Panel
                </a>
                <a
                    href={siteConfig.links.billing}
                    class="btn-primary text-sm"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Billing Portal
                </a>
            </nav>

            <!-- Mobile Menu Button -->
            <button
                id="mobile-menu-btn"
                class="md:hidden p-2 text-lumix-gray hover:text-lumix-white"
                aria-label="Toggle menu"
            >
                <svg
                    class="w-6 h-6"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M4 6h16M4 12h16M4 18h16"></path>
                </svg>
            </button>
        </div>
    </div>

    <!-- Mobile Navigation -->
    <div
        id="mobile-menu"
        class="hidden md:hidden border-t border-terminal-border bg-lumix-black"
    >
        <div class="px-4 py-4 space-y-1">
            {
                navigation.map((item) => (
                    <a
                        href={item.href}
                        class="block px-4 py-3 text-sm text-lumix-gray hover:text-lumix-white hover:bg-lumix-black-light transition-colors"
                    >
                        {item.name}
                    </a>
                ))
            }
            <div class="pt-4 mt-4 border-t border-terminal-border space-y-2">
                <a
                    href={siteConfig.links.panel}
                    class="btn-primary w-full text-center"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Panel
                </a>
                <a
                    href={siteConfig.links.billing}
                    class="btn-primary w-full text-center"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Billing Portal
                </a>
            </div>
        </div>
    </div>
</header>

<!-- Spacer for fixed header -->
<div class="h-16"></div>

<script>
    const mobileMenuBtn = document.getElementById("mobile-menu-btn");
    const mobileMenu = document.getElementById("mobile-menu");

    mobileMenuBtn?.addEventListener("click", () => {
        mobileMenu?.classList.toggle("hidden");
    });

    // Close menu when clicking a link
    mobileMenu?.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", () => {
            mobileMenu?.classList.add("hidden");
        });
    });
</script>
