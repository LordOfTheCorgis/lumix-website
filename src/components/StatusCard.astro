---
interface Props {
    id: string;
    name: string;
    endpoint: string;
    pingUrl: string;
    status: "operational" | "degraded" | "down" | "checking";
    uptime: number;
    responseTime: number;
}

const { id, name, endpoint, pingUrl, status, uptime, responseTime } = Astro.props;

const statusLabels = {
    operational: "Operational",
    degraded: "Degraded",
    down: "Down",
    checking: "Checking...",
};

const statusClasses = {
    operational: "status-operational",
    degraded: "status-degraded",
    down: "status-down",
    checking: "status-degraded",
};
---

<div class="card p-4 sm:p-5" data-service-id={id} data-ping-url={pingUrl}>
    <div class="flex items-start justify-between gap-4">
        <div class="flex-1 min-w-0">
            <div class="flex items-center gap-3 mb-2">
                <span 
                    class={`status-dot status-pulse ${statusClasses[status]}`}
                    data-status-dot
                ></span>
                <h3 class="text-sm font-medium text-lumix-white truncate">
                    {name}
                </h3>
            </div>
            <div class="text-mono text-xs text-lumix-gray truncate">
                {endpoint}
            </div>
        </div>
        <div class="text-right flex-shrink-0">
            <div
                class={`text-xs font-medium ${
                    status === "operational"
                        ? "text-terminal-green"
                        : status === "degraded"
                            ? "text-terminal-yellow"
                            : "text-lumix-red"
                }`}
                data-status-label
            >
                {statusLabels[status]}
            </div>
        </div>
    </div>

    <div class="mt-4 pt-4 border-t border-terminal-border">
        <div class="grid grid-cols-2 gap-4">
            <div>
                <div class="text-mono text-xs text-lumix-gray mb-1">Uptime</div>
                <div class="text-sm text-lumix-white" data-uptime>{uptime.toFixed(2)}%</div>
            </div>
            <div>
                <div class="text-mono text-xs text-lumix-gray mb-1">
                    Response
                </div>
                <div class="text-sm text-lumix-white" data-response-time>{responseTime}ms</div>
            </div>
        </div>
    </div>
    
    <!-- Ping Button -->
    <div class="mt-4 pt-4 border-t border-terminal-border">
        <button 
            class="btn-outline w-full text-xs py-2"
            data-ping-btn
        >
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" data-ping-icon>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.636 18.364a9 9 0 010-12.728m12.728 0a9 9 0 010 12.728m-9.9-2.829a5 5 0 010-7.07m7.072 0a5 5 0 010 7.07M13 12a1 1 0 11-2 0 1 1 0 012 0z" />
            </svg>
            <span data-ping-text>Ping Service</span>
        </button>
    </div>
</div>
