---
import Layout from "../../layouts/Layout.astro";
import GameTile from "../../components/GameTile.astro";
import Terminal from "../../components/Terminal.astro";
import { catalog, liveCategories } from "../../data/catalog";
import { siteConfig, stats } from "../../data/site";
---

<Layout
  title="Game Server Hosting"
  description="Deploy FiveM, Minecraft, Terraria, and application servers on Lumix infrastructure. Pick a plan, pick a location, and you are online in minutes."
>
  <!-- Hero, mirroring the homepage layout -->
  <section class="relative flex items-center overflow-hidden">
    <div class="grid-overlay pointer-events-none absolute inset-0"></div>

    <div class="relative mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8 lg:py-28">
      <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
        <div>
          <div class="text-mono mb-4 animate-fade-in text-xs text-lumix-gray">
            <span class="text-lumix-red">[</span> GAME_HOSTING <span class="text-lumix-red">]</span> // catalog
          </div>

          <h1 class="heading-xl mb-6 animate-fade-in-up animate-delay-100 text-lumix-white">
            Build your server<br />
            <span class="text-lumix-red">in about a minute</span>
          </h1>

          <p class="body-lg mb-8 max-w-lg animate-fade-in-up animate-delay-200 text-lumix-gray">
            Pick a game, size the plan, choose a location. Your whole configuration
            carries into checkout with nothing to re-select.
          </p>

          <div class="flex flex-wrap gap-4 animate-fade-in-up animate-delay-300">
            <a href="#catalog" class="btn-primary">
              Browse Games
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>
            <a href="/contact" class="btn-outline">Talk to an engineer</a>
          </div>
        </div>

        <div class="animate-fade-in-up animate-delay-400">
          <Terminal
            title="lumix@deploy ~ $"
            lines={[
              { prompt: "$", command: "lumix catalog --available" },
              { output: "Resolving node capacity...", type: "info" },
              { output: "" },
              { output: "GAME               NODES      STATUS", type: "info" },
              { output: "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━", type: "info" },
              { output: "fivem              ONLINE     ACCEPTING", type: "success" },
              { output: "minecraft          ONLINE     ACCEPTING", type: "success" },
              { output: "palworld           ONLINE     ACCEPTING", type: "success" },
              { output: "beammp             ONLINE     ACCEPTING", type: "success" },
              { output: "" },
              { output: "Ready to provision.", type: "success" },
            ]}
          />
        </div>
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- Stats band, same rhythm as the homepage -->
  <section class="py-16 lg:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 gap-8 lg:grid-cols-4 lg:gap-12">
        {
          stats.map((stat) => (
            <div class="text-center lg:text-left" data-animate>
              <div class="text-mono mb-1 text-3xl font-bold text-lumix-white lg:text-4xl">
                {stat.value}
                <span class="text-xl text-lumix-red lg:text-2xl">{stat.unit}</span>
              </div>
              <div class="text-sm text-lumix-gray">{stat.label}</div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- One catalog. Unavailable titles are dimmed in place rather than exiled
       to a separate section. -->
  <section id="catalog" class="py-16 lg:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <span class="text-mono mb-4 block text-xs text-lumix-gray">// CATALOG</span>
          <h2 class="heading-lg text-lumix-white">Every game we run</h2>
          <p class="mt-3 max-w-xl text-lumix-gray">
            Dimmed titles are not orderable yet. Ask for one in Discord and we will
            prioritise by demand.
          </p>
        </div>
        <span class="text-mono shrink-0 text-xs text-lumix-gray-dark">
          {liveCategories.length} live / {catalog.length} total
        </span>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {catalog.map((category, index) => <GameTile category={category} eager={index < 4} />)}
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- CTA, matching the homepage treatment -->
  <section class="py-16 lg:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="relative overflow-hidden border border-terminal-border p-8 lg:p-16">
        <div class="grid-overlay pointer-events-none absolute inset-0 opacity-20"></div>

        <div class="relative mx-auto max-w-2xl text-center">
          <div class="text-mono mb-4 text-xs text-lumix-red">$ request --game</div>
          <h2 class="heading-lg mb-4 text-lumix-white">Not seeing your game?</h2>
          <p class="mb-8 text-lumix-gray">
            We add titles based on what people actually ask for. Tell us what you want
            to run and we will tell you when it is coming.
          </p>
          <div class="flex flex-wrap justify-center gap-4">
            <a href={siteConfig.links.discord} target="_blank" rel="noopener noreferrer" class="btn-primary">
              Request a game
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>
            <a href="/contact" class="btn-outline">Contact sales</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
