---
import Layout from "../layouts/Layout.astro";
import Terminal from "../components/Terminal.astro";
import ServiceCard from "../components/ServiceCard.astro";
import { siteConfig, services, stats } from "../data/site";
---

<Layout title="Lumix">
  <!-- Hero Section -->
  <section class="relative min-h-[90vh] flex items-center overflow-hidden">
    <!-- Grid Background -->
    <div class="absolute inset-0 grid-overlay pointer-events-none"></div>
    
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-32">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Left: Content -->
        <div>
          <div class="text-mono text-xs text-lumix-gray mb-4 animate-fade-in">
            <span class="text-lumix-red">[</span> LUMIX_SOLUTIONS <span class="text-lumix-red">]</span> // infrastructure
          </div>
          
          <h1 class="heading-xl text-lumix-white mb-6 animate-fade-in-up animate-delay-100">
            Infrastructure built<br/>
            <span class="text-lumix-red">by engineers</span>
          </h1>
          
          <p class="body-lg text-lumix-gray max-w-lg mb-8 animate-fade-in-up animate-delay-200">
            Reliable compute, game server hosting, voice infrastructure, and 
            enterprise-grade DDoS protection. No buzzwords, just infrastructure 
            that works.
          </p>
          
          <div class="flex flex-wrap gap-4 animate-fade-in-up animate-delay-300">
            <a href={siteConfig.links.billing} target="_blank" rel="noopener noreferrer" class="btn-primary">
              Deploy Now
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>
            <a href="/services" class="btn-outline">
              View Services
            </a>
          </div>
        </div>
        
        <!-- Right: Terminal -->
        <div class="animate-fade-in-up animate-delay-400">
          <Terminal 
            title="lumix@infra ~ $"
            lines={[
              { prompt: "$", command: "lumix status --all" },
              { output: "Checking infrastructure status...", type: "info" },
              { output: "" },
              { output: "SERVICES           STATUS      UPTIME", type: "info" },
              { output: "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━", type: "info" },
              { output: "ddos_shield        ACTIVE      99.99%", type: "success" },
              { output: "compute_nodes      ACTIVE      99.98%", type: "success" },
              { output: "game_servers       ACTIVE      99.97%", type: "success" },
              { output: "voice_infra        ACTIVE      99.95%", type: "success" },
              { output: "" },
              { output: "All systems operational.", type: "success" },
            ]}
          />
        </div>
      </div>
    </div>
  </section>
  
  <div class="section-divider"></div>
  
  <!-- Stats Section -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
        {stats.map((stat, index) => (
          <div class="text-center lg:text-left" data-animate>
            <div class="text-mono text-3xl lg:text-4xl font-bold text-lumix-white mb-1">
              {stat.value}
              <span class="text-lumix-red text-xl lg:text-2xl">{stat.unit}</span>
            </div>
            <div class="text-sm text-lumix-gray">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>
  
  <div class="section-divider"></div>
  
  <!-- What We Do Section -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-start">
        <!-- Left: Text -->
        <div>
          <span class="text-mono text-xs text-lumix-gray mb-4 block">// OVERVIEW</span>
          <h2 class="heading-lg text-lumix-white mb-6">
            What we do
          </h2>
          <div class="space-y-4 text-lumix-gray">
            <p>
              Lumix Solutions provides infrastructure services for businesses and 
              developers who need reliability without the corporate overhead.
            </p>
            <p>
              We specialize in <span class="text-lumix-white">Node.js application hosting</span>, 
              <span class="text-lumix-white">game server infrastructure</span>, 
              <span class="text-lumix-white">voice communication servers</span>, and 
              <span class="text-lumix-white">DDoS mitigation</span>.
            </p>
            <p>
              Our team comes from backgrounds in systems administration, network 
              engineering, and software development. We build what we'd want to use.
            </p>
          </div>
          
          <div class="mt-8 pt-8 border-t border-terminal-border">
            <div class="text-mono text-xs text-lumix-gray mb-3">SUPPORTED PLATFORMS</div>
            <div class="flex flex-wrap gap-3">
              {['Node.js', 'Python', 'Docker', 'TeamSpeak', 'Mumble', 'Game Servers'].map(platform => (
                <span class="px-3 py-1 text-xs text-lumix-gray border border-terminal-border">
                  {platform}
                </span>
              ))}
            </div>
          </div>
        </div>
        
        <!-- Right: Terminal -->
        <div class="lg:sticky lg:top-24">
          <Terminal 
            title="infrastructure.log"
            showCursor={false}
            lines={[
              { output: "[2026-01-30 12:00:01] DDoS mitigation active", type: "success" },
              { output: "[2026-01-30 12:00:01] Scrubbing capacity: 10Tbps+", type: "info" },
              { output: "[2026-01-30 12:00:02] Game servers: 847 active", type: "success" },
              { output: "[2026-01-30 12:00:02] Avg latency: 8ms", type: "info" },
              { output: "[2026-01-30 12:00:03] Voice servers: 234 online", type: "success" },
              { output: "[2026-01-30 12:00:03] Codec: Opus @ 128kbps", type: "info" },
              { output: "[2026-01-30 12:00:04] Compute nodes: healthy", type: "success" },
              { output: "[2026-01-30 12:00:05] Network: no incidents", type: "success" },
            ]}
          />
        </div>
      </div>
    </div>
  </section>
  
  <div class="section-divider"></div>
  
  <!-- Services Preview -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-12">
        <div>
          <span class="text-mono text-xs text-lumix-gray mb-4 block">// SERVICES</span>
          <h2 class="heading-lg text-lumix-white">
            Our infrastructure
          </h2>
        </div>
        <a href="/services" class="btn-outline">
          View All Services
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
      
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.slice(0, 3).map(service => (
          <ServiceCard {...service} />
        ))}
      </div>
    </div>
  </section>
  
  <div class="section-divider"></div>
  
  <!-- CTA Section -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="relative border border-terminal-border p-8 lg:p-16 overflow-hidden">
        <!-- Background grid -->
        <div class="absolute inset-0 grid-overlay opacity-20 pointer-events-none"></div>
        
        <div class="relative text-center max-w-2xl mx-auto">
          <div class="text-mono text-xs text-lumix-red mb-4">
            $ deploy --production
          </div>
          <h2 class="heading-lg text-lumix-white mb-4">
            Ready to deploy?
          </h2>
          <p class="text-lumix-gray mb-8">
            Access our billing portal to configure your infrastructure. 
            Hourly billing, no long-term contracts, cancel anytime.
          </p>
          <div class="flex flex-wrap justify-center gap-4">
            <a href={siteConfig.links.billing} target="_blank" rel="noopener noreferrer" class="btn-primary">
              Access Billing Portal
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>
            <a href="/contact" class="btn-outline">
              Contact Sales
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
