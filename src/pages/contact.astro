---
import Layout from "../layouts/Layout.astro";
import Terminal from "../components/Terminal.astro";
import { siteConfig } from "../data/site";
---

<Layout title="Contact" description="Get in touch with Lumix Solutions for sales inquiries, support, or partnership opportunities.">
  <!-- Page Header -->
  <section class="py-16 lg:py-24 border-b border-terminal-border">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <span class="text-mono text-xs text-lumix-gray mb-4 block animate-fade-in">
          <span class="text-lumix-red">$</span> lumix contact --init
        </span>
        <h1 class="heading-xl text-lumix-white mb-6 animate-fade-in-up animate-delay-100">
          Get in <span class="text-lumix-red">touch</span>
        </h1>
        <p class="body-lg text-lumix-gray animate-fade-in-up animate-delay-200">
          Questions about our services? Need a custom solution? 
          We're here to help.
        </p>
      </div>
    </div>
  </section>
  
  <!-- Contact Content -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20">
        <!-- Left: Contact Options -->
        <div>
          <span class="text-mono text-xs text-lumix-gray mb-6 block">// CONTACT_METHODS</span>
          
          <div class="space-y-6">
            <!-- Email -->
            <div class="card p-6 group">
              <div class="flex items-start gap-4">
                <div class="p-3 bg-lumix-black border border-terminal-border">
                  <svg class="w-5 h-5 text-lumix-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                  </svg>
                </div>
                <div class="flex-1">
                  <h3 class="text-lumix-white font-medium mb-1">General Inquiries</h3>
                  <p class="text-sm text-lumix-gray mb-3">
                    For questions about our services or partnership opportunities.
                  </p>
                  <a 
                    href={`mailto:${siteConfig.contact.email}`}
                    class="text-mono text-sm text-lumix-red hover:underline"
                  >
                    {siteConfig.contact.email}
                  </a>
                </div>
              </div>
            </div>
            
            <!-- Support -->
            <div class="card p-6 group">
              <div class="flex items-start gap-4">
                <div class="p-3 bg-lumix-black border border-terminal-border">
                  <svg class="w-5 h-5 text-lumix-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z" />
                  </svg>
                </div>
                <div class="flex-1">
                  <h3 class="text-lumix-white font-medium mb-1">Technical Support</h3>
                  <p class="text-sm text-lumix-gray mb-3">
                    Existing customers can reach our support team 24/7.
                  </p>
                  <a 
                    href={`mailto:${siteConfig.contact.support}`}
                    class="text-mono text-sm text-lumix-red hover:underline"
                  >
                    {siteConfig.contact.support}
                  </a>
                </div>
              </div>
            </div>
            
            <!-- Billing -->
            <div class="card p-6 group">
              <div class="flex items-start gap-4">
                <div class="p-3 bg-lumix-black border border-terminal-border">
                  <svg class="w-5 h-5 text-lumix-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z" />
                  </svg>
                </div>
                <div class="flex-1">
                  <h3 class="text-lumix-white font-medium mb-1">Billing & Account</h3>
                  <p class="text-sm text-lumix-gray mb-3">
                    Manage your services, view invoices, and handle billing through our portal.
                  </p>
                  <a 
                    href={siteConfig.links.billing}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-mono text-sm text-lumix-red hover:underline inline-flex items-center gap-1"
                  >
                    billing.lumixsolutions.org
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                    </svg>
                  </a>
                </div>
              </div>
            </div>
            
            <!-- Discord -->
            <div class="card p-6 group">
              <div class="flex items-start gap-4">
                <div class="p-3 bg-lumix-black border border-terminal-border">
                  <svg class="w-5 h-5 text-lumix-red" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
                  </svg>
                </div>
                <div class="flex-1">
                  <h3 class="text-lumix-white font-medium mb-1">Community</h3>
                  <p class="text-sm text-lumix-gray mb-3">
                    Join our Discord for community support and announcements.
                  </p>
                  <a 
                    href={siteConfig.links.discord}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-mono text-sm text-lumix-red hover:underline inline-flex items-center gap-1"
                  >
                    Join Discord
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                    </svg>
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Right: Terminal + Info -->
        <div>
          <Terminal 
            title="contact --info"
            showCursor={false}
            lines={[
              { prompt: "$", command: "lumix contact --info" },
              { output: "" },
              { output: "LUMIX SOLUTIONS", type: "info" },
              { output: "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━", type: "info" },
              { output: "" },
              { output: "Response times:", type: "info" },
              { output: "  General inquiries: < 24 hours", type: "success" },
              { output: "  Technical support: < 4 hours", type: "success" },
              { output: "  Critical issues:   < 1 hour", type: "success" },
              { output: "" },
              { output: "Support hours:", type: "info" },
              { output: "  24/7/365 for existing customers", type: "success" },
              { output: "" },
              { output: "Preferred contact:", type: "info" },
              { output: "  Billing portal ticket system", type: "info" },
              { output: "" },
            ]}
          />
          
          <div class="mt-8 p-6 border border-terminal-border">
            <h3 class="text-mono text-xs text-lumix-gray-light uppercase tracking-wider mb-4">
              Before contacting support
            </h3>
            <ul class="space-y-3 text-sm text-lumix-gray">
              <li class="flex items-start gap-2">
                <span class="text-lumix-red">›</span>
                Check our <a href="/status" class="text-lumix-white hover:text-lumix-red">status page</a> for known issues
              </li>
              <li class="flex items-start gap-2">
                <span class="text-lumix-red">›</span>
                Review your service configuration in the billing portal
              </li>
              <li class="flex items-start gap-2">
                <span class="text-lumix-red">›</span>
                Include relevant error messages and timestamps
              </li>
              <li class="flex items-start gap-2">
                <span class="text-lumix-red">›</span>
                For billing issues, have your invoice ID ready
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
