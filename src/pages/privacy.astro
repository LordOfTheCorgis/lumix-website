---
import Layout from "../layouts/Layout.astro";
import { siteConfig } from "../data/site";

const lastUpdated = "January 30, 2026";
---

<Layout title="Privacy Policy" description="Privacy Policy for Lumix Solutions - Learn how we collect, use, and protect your data.">
  <section class="py-16 lg:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <span class="text-mono text-xs text-lumix-gray mb-4 block">
          <span class="text-lumix-red">$</span> cat /legal/privacy.md
        </span>
        <h1 class="heading-xl text-lumix-white mb-4">
          Privacy <span class="text-lumix-red">Policy</span>
        </h1>
        <p class="text-lumix-gray">
          Last updated: {lastUpdated}
        </p>
      </div>

      <div class="prose prose-invert max-w-none space-y-8">
        <!-- Introduction -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-4">1. Introduction</h2>
          <div class="text-lumix-gray space-y-4 text-sm">
            <p>
              Lumix Solutions ("we," "our," or "us") is committed to protecting your privacy. 
              This Privacy Policy explains how we collect, use, disclose, and safeguard your 
              information when you use our web hosting services, visit our website at 
              lumixsolutions.org, or interact with us in any way.
            </p>
            <p>
              By using our services, you agree to the collection and use of information in 
              accordance with this policy. If you do not agree with the terms of this privacy 
              policy, please do not access our services.
            </p>
          </div>
        </section>

        <!-- Information We Collect -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-4">2. Information We Collect</h2>
          <div class="text-lumix-gray space-y-4 text-sm">
            <h3 class="text-lumix-white font-medium mt-4">Personal Information</h3>
            <p>We may collect personal information that you voluntarily provide, including:</p>
            <ul class="list-disc list-inside space-y-2 ml-4">
              <li>Name and contact information (email address, phone number)</li>
              <li>Billing information (credit card details, billing address)</li>
              <li>Account credentials (username, password)</li>
              <li>Company information (if applicable)</li>
              <li>Support ticket communications</li>
            </ul>

            <h3 class="text-lumix-white font-medium mt-6">Automatically Collected Information</h3>
            <p>When you access our services, we automatically collect:</p>
            <ul class="list-disc list-inside space-y-2 ml-4">
              <li>IP addresses and geolocation data</li>
              <li>Browser type and version</li>
              <li>Operating system information</li>
              <li>Access times and dates</li>
              <li>Pages viewed and actions taken</li>
              <li>Referring URLs</li>
            </ul>

            <h3 class="text-lumix-white font-medium mt-6">Server and Service Data</h3>
            <p>For the operation of hosting services, we may collect:</p>
            <ul class="list-disc list-inside space-y-2 ml-4">
              <li>Server logs and performance metrics</li>
              <li>Network traffic data (for DDoS protection)</li>
              <li>Resource usage statistics</li>
              <li>Error logs and diagnostic information</li>
            </ul>
          </div>
        </section>

        <!-- How We Use Information -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-4">3. How We Use Your Information</h2>
          <div class="text-lumix-gray space-y-4 text-sm">
            <p>We use collected information for the following purposes:</p>
            <ul class="list-disc list-inside space-y-2 ml-4">
              <li>Providing, operating, and maintaining our services</li>
              <li>Processing transactions and billing</li>
              <li>Responding to support requests and communications</li>
              <li>Detecting and preventing fraud, abuse, and security threats</li>
              <li>Providing DDoS mitigation and network protection</li>
              <li>Improving and optimizing our services</li>
              <li>Sending service-related notifications and updates</li>
              <li>Complying with legal obligations</li>
            </ul>
          </div>
        </section>

        <!-- Data Sharing -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-4">4. Information Sharing and Disclosure</h2>
          <div class="text-lumix-gray space-y-4 text-sm">
            <p>We do not sell your personal information. We may share information with:</p>
            <ul class="list-disc list-inside space-y-2 ml-4">
              <li><strong class="text-lumix-white">Service Providers:</strong> Third-party vendors who assist in operating our services (payment processors, data centers, support tools)</li>
              <li><strong class="text-lumix-white">Legal Requirements:</strong> When required by law, subpoena, or government request</li>
              <li><strong class="text-lumix-white">Protection of Rights:</strong> To protect our rights, privacy, safety, or property</li>
              <li><strong class="text-lumix-white">Business Transfers:</strong> In connection with a merger, acquisition, or sale of assets</li>
            </ul>
          </div>
        </section>

        <!-- Data Security -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-4">5. Data Security</h2>
          <div class="text-lumix-gray space-y-4 text-sm">
            <p>
              We implement industry-standard security measures to protect your information, including:
            </p>
            <ul class="list-disc list-inside space-y-2 ml-4">
              <li>Encryption of data in transit (TLS/SSL) and at rest</li>
              <li>Regular security audits and vulnerability assessments</li>
              <li>Access controls and authentication mechanisms</li>
              <li>Network monitoring and intrusion detection</li>
              <li>Physical security at data center facilities</li>
            </ul>
            <p class="mt-4">
              While we strive to protect your information, no method of transmission over the 
              Internet is 100% secure. We cannot guarantee absolute security.
            </p>
          </div>
        </section>

        <!-- Data Retention -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-4">6. Data Retention</h2>
          <div class="text-lumix-gray space-y-4 text-sm">
            <p>
              We retain your information for as long as necessary to provide our services and 
              fulfill the purposes described in this policy. Specifically:
            </p>
            <ul class="list-disc list-inside space-y-2 ml-4">
              <li>Account information: Retained while your account is active and for 30 days after termination</li>
              <li>Billing records: Retained for 7 years for tax and legal compliance</li>
              <li>Server logs: Retained for 90 days for security and troubleshooting</li>
              <li>Support tickets: Retained for 2 years after resolution</li>
            </ul>
          </div>
        </section>

        <!-- Your Rights -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-4">7. Your Rights</h2>
          <div class="text-lumix-gray space-y-4 text-sm">
            <p>Depending on your location, you may have the following rights:</p>
            <ul class="list-disc list-inside space-y-2 ml-4">
              <li><strong class="text-lumix-white">Access:</strong> Request a copy of your personal information</li>
              <li><strong class="text-lumix-white">Correction:</strong> Request correction of inaccurate information</li>
              <li><strong class="text-lumix-white">Deletion:</strong> Request deletion of your personal information</li>
              <li><strong class="text-lumix-white">Portability:</strong> Request transfer of your data to another service</li>
              <li><strong class="text-lumix-white">Opt-out:</strong> Opt out of marketing communications</li>
            </ul>
            <p class="mt-4">
              To exercise these rights, contact us at <a href={`mailto:${siteConfig.contact.email}`} class="text-lumix-red hover:underline">{siteConfig.contact.email}</a>
            </p>
          </div>
        </section>

        <!-- Cookies -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-4">8. Cookies and Tracking</h2>
          <div class="text-lumix-gray space-y-4 text-sm">
            <p>
              We use cookies and similar tracking technologies to improve your experience. 
              These include:
            </p>
            <ul class="list-disc list-inside space-y-2 ml-4">
              <li><strong class="text-lumix-white">Essential Cookies:</strong> Required for service functionality</li>
              <li><strong class="text-lumix-white">Analytics Cookies:</strong> Help us understand how you use our services</li>
              <li><strong class="text-lumix-white">Preference Cookies:</strong> Remember your settings and preferences</li>
            </ul>
            <p class="mt-4">
              You can control cookies through your browser settings. Disabling certain cookies 
              may affect service functionality.
            </p>
          </div>
        </section>

        <!-- International Transfers -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-4">9. International Data Transfers</h2>
          <div class="text-lumix-gray space-y-4 text-sm">
            <p>
              Your information may be transferred to and processed in countries other than your 
              own. Our data centers are located in multiple regions to provide optimal service. 
              We ensure appropriate safeguards are in place for international transfers.
            </p>
          </div>
        </section>

        <!-- Children -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-4">10. Children's Privacy</h2>
          <div class="text-lumix-gray space-y-4 text-sm">
            <p>
              Our services are not intended for individuals under 18 years of age. We do not 
              knowingly collect personal information from children. If you believe we have 
              collected information from a minor, please contact us immediately.
            </p>
          </div>
        </section>

        <!-- Changes -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-4">11. Changes to This Policy</h2>
          <div class="text-lumix-gray space-y-4 text-sm">
            <p>
              We may update this Privacy Policy from time to time. We will notify you of any 
              changes by posting the new policy on this page and updating the "Last updated" 
              date. Continued use of our services after changes constitutes acceptance of the 
              updated policy.
            </p>
          </div>
        </section>

        <!-- Contact -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-4">12. Contact Us</h2>
          <div class="text-lumix-gray space-y-4 text-sm">
            <p>
              If you have questions about this Privacy Policy or our data practices, contact us:
            </p>
            <div class="mt-4 p-4 bg-lumix-black border border-terminal-border">
              <p class="text-mono text-sm">
                <span class="text-lumix-gray">Email:</span> <a href={`mailto:${siteConfig.contact.email}`} class="text-lumix-red">{siteConfig.contact.email}</a><br/>
                <span class="text-lumix-gray">Website:</span> <span class="text-lumix-white">lumixsolutions.org</span>
              </p>
            </div>
          </div>
        </section>
      </div>
    </div>
  </section>
</Layout>
