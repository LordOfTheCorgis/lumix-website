---
import Layout from "../layouts/Layout.astro";
import { siteConfig } from "../data/site";

const lastUpdated = "May 1, 2026";
---

<Layout title="Privacy Policy" description="Privacy Policy for Lumix Solutions - Learn how we collect, use, and protect your data.">
  <section class="py-16 lg:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <span class="text-mono text-xs text-lumix-gray mb-4 block">
          <span class="text-lumix-red">$</span> cat /legal/privacy.md
        </span>
        <h1 class="heading-xl text-lumix-white mb-4">
          Privacy <span class="text-lumix-red">Policy</span>
        </h1>
        <p class="text-lumix-gray">
          Last updated: {lastUpdated}
        </p>
      </div>

      <div class="prose prose-invert max-w-none space-y-8">

        <!-- 1 -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-4">1. Introduction</h2>
          <div class="text-lumix-gray text-sm space-y-4">
            <p>
              Lumix Solutions ("we," "our," or "us") provides web hosting and related infrastructure services. 
              This Privacy Policy explains how we collect, use, disclose, and safeguard your information.
            </p>
            <p>
              By using our services, you agree to this policy. If you do not agree, do not use our services.
            </p>
          </div>
        </section>

        <!-- 2 -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-4">2. Information We Collect</h2>
          <div class="text-lumix-gray text-sm space-y-4">

            <h3 class="text-lumix-white">Personal Information</h3>
            <ul class="list-disc list-inside ml-4 space-y-2">
              <li>Name, email, phone number</li>
              <li>Billing details (address, payment info)</li>
              <li>Account credentials</li>
              <li>Support communications</li>
            </ul>

            <h3 class="text-lumix-white mt-4">Automatically Collected</h3>
            <ul class="list-disc list-inside ml-4 space-y-2">
              <li>IP address and approximate location</li>
              <li>Device and browser data</li>
              <li>Usage activity and timestamps</li>
              <li>Referring/exit pages</li>
            </ul>

            <h3 class="text-lumix-white mt-4">Service Data</h3>
            <ul class="list-disc list-inside ml-4 space-y-2">
              <li>Server logs and diagnostics</li>
              <li>Traffic patterns (for DDoS mitigation)</li>
              <li>Resource usage</li>
            </ul>
          </div>
        </section>

        <!-- 3 -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-4">3. How We Use Information</h2>
          <ul class="text-lumix-gray text-sm list-disc list-inside ml-4 space-y-2">
            <li>Provide and maintain services</li>
            <li>Process billing</li>
            <li>Respond to support requests</li>
            <li>Prevent abuse, fraud, and attacks</li>
            <li>Improve performance and reliability</li>
            <li>Comply with legal obligations</li>
          </ul>
        </section>

        <!-- 4 -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-4">4. Information Sharing</h2>
          <ul class="text-lumix-gray text-sm list-disc list-inside ml-4 space-y-2">
            <li>Service providers (payments, infrastructure, support tools)</li>
            <li>Legal authorities when required</li>
            <li>Business transfers (mergers, acquisitions)</li>
          </ul>
          <p class="text-lumix-gray text-sm mt-4">
            We do not sell personal data.
          </p>
        </section>

        <!-- 5 -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-4">5. Data Security</h2>
          <div class="text-lumix-gray text-sm space-y-4">
            <ul class="list-disc list-inside ml-4 space-y-2">
              <li>Encryption (TLS/SSL)</li>
              <li>Access controls</li>
              <li>Monitoring and intrusion detection</li>
              <li>Security audits</li>
            </ul>
            <p>
              In case of a breach, we will notify affected users as required by law.
            </p>
          </div>
        </section>

        <!-- 6 -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-4">6. Data Retention</h2>
          <ul class="text-lumix-gray text-sm list-disc list-inside ml-4 space-y-2">
            <li>Accounts: active + 30 days</li>
            <li>Billing: up to 7 years</li>
            <li>Logs: up to 90 days</li>
            <li>Support tickets: 2 years</li>
          </ul>
          <p class="text-lumix-gray text-sm mt-4">
            Data may be deleted or anonymized upon request unless legally required.
          </p>
        </section>

        <!-- 7 -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-4">7. Your Rights</h2>
          <ul class="text-lumix-gray text-sm list-disc list-inside ml-4 space-y-2">
            <li>Access your data</li>
            <li>Correct inaccuracies</li>
            <li>Request deletion</li>
            <li>Data portability</li>
            <li>Opt-out of communications</li>
          </ul>
          <p class="text-sm mt-4">
            Contact: <a href={`mailto:${siteConfig.contact.email}`} class="text-lumix-red">{siteConfig.contact.email}</a>
          </p>
        </section>

        <!-- 8 -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-4">8. Cookies</h2>
          <div class="text-lumix-gray text-sm space-y-4">
            <p>We use cookies for functionality, analytics, and preferences.</p>
            <ul class="list-disc list-inside ml-4 space-y-2">
              <li>Session cookies</li>
              <li>Persistent cookies</li>
              <li>Analytics tools</li>
            </ul>
          </div>
        </section>

        <!-- 9 -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-4">9. International Transfers</h2>
          <p class="text-lumix-gray text-sm">
            Data may be processed in multiple regions with safeguards in place.
          </p>
        </section>

        <!-- 10 -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-4">10. Children's Privacy</h2>
          <p class="text-lumix-gray text-sm">
            Services are not intended for users under 18.
          </p>
        </section>

        <!-- 11 -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-4">11. Changes</h2>
          <p class="text-lumix-gray text-sm">
            Continued use after updates means acceptance of changes.
          </p>
        </section>

        <!-- 12 -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-4">12. Contact</h2>
          <p class="text-lumix-gray text-sm">
            Email: <a href={`mailto:${siteConfig.contact.email}`} class="text-lumix-red">{siteConfig.contact.email}</a>
          </p>
        </section>

        <!-- 13 -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-4">13. Customer Data</h2>
          <p class="text-lumix-gray text-sm">
            Customers are responsible for data they host. We act as a processor.
          </p>
        </section>

        <!-- 14 -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-4">14. Legal Basis</h2>
          <ul class="text-lumix-gray text-sm list-disc list-inside ml-4 space-y-2">
            <li>Contract</li>
            <li>Legal obligation</li>
            <li>Legitimate interest</li>
            <li>Consent</li>
          </ul>
        </section>

        <!-- 15 -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-4">15. U.S. Rights</h2>
          <p class="text-lumix-gray text-sm">
            Users may request access, deletion, or correction of personal data.
          </p>
        </section>

        <!-- 16 -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-4">16. Subprocessors</h2>
          <p class="text-lumix-gray text-sm">
            We use third-party providers bound by data protection agreements.
          </p>
        </section>

      </div>
    </div>
  </section>
</Layout>
