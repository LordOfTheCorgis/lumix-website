---
import Layout from "../layouts/Layout.astro";
import { siteConfig } from "../data/site";

const lastUpdated = "May 1, 2026";
---

<Layout title="California Privacy Notice" description="California Consumer Privacy Act (CCPA) Notice for Lumix Solutions - Your California Privacy Rights.">
  <section class="py-16 lg:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="mb-12">
        <span class="text-mono text-xs text-lumix-gray mb-4 block">
          <span class="text-lumix-red">$</span> cat /legal/ccpa.md
        </span>

        <h1 class="heading-xl text-lumix-white mb-4">
          California <span class="text-lumix-red">Privacy</span> Notice
        </h1>

        <p class="text-lumix-gray">
          Last updated: {lastUpdated}
        </p>
      </div>

      <div class="prose prose-invert max-w-none space-y-8">

        <!-- 1 -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-4">California Consumer Privacy Act (CCPA)</h2>
          <div class="text-lumix-gray text-sm space-y-4">
            <p>
              This Notice supplements our Privacy Policy and applies to California residents.
              It explains how we collect, use, and disclose personal information under the California Consumer Privacy Act (CCPA)
              and California Privacy Rights Act (CPRA).
            </p>

            <p>
              We act as a service provider in many cases when processing data on behalf of customers using our hosting infrastructure.
            </p>
          </div>
        </section>

        <!-- 2 -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-4">Categories of Personal Information Collected</h2>
          <div class="text-lumix-gray text-sm space-y-4">

            <p>In the past 12 months, we have collected the following categories:</p>

            <div class="space-y-4 mt-6">

              <div class="p-4 bg-lumix-black border border-terminal-border">
                <h4 class="text-lumix-white font-medium">Identifiers</h4>
                <p class="text-xs">Name, email, IP address, account ID, device identifiers</p>
              </div>

              <div class="p-4 bg-lumix-black border border-terminal-border">
                <h4 class="text-lumix-white font-medium">Customer Records</h4>
                <p class="text-xs">Billing info, payment details, contact information</p>
              </div>

              <div class="p-4 bg-lumix-black border border-terminal-border">
                <h4 class="text-lumix-white font-medium">Commercial Information</h4>
                <p class="text-xs">Service usage, purchases, subscription history</p>
              </div>

              <div class="p-4 bg-lumix-black border border-terminal-border">
                <h4 class="text-lumix-white font-medium">Internet Activity</h4>
                <p class="text-xs">Logs, browsing behavior, interactions with services</p>
              </div>

              <div class="p-4 bg-lumix-black border border-terminal-border">
                <h4 class="text-lumix-white font-medium">Geolocation Data</h4>
                <p class="text-xs">IP-based location for fraud prevention and security</p>
              </div>

              <div class="p-4 bg-lumix-black border border-terminal-border">
                <h4 class="text-lumix-white font-medium">Professional Data</h4>
                <p class="text-xs">Company name or role (if provided)</p>
              </div>

              <div class="p-4 bg-lumix-black border border-terminal-border">
                <h4 class="text-lumix-white font-medium">Inferences</h4>
                <p class="text-xs">Service preferences derived from usage patterns</p>
              </div>

            </div>
          </div>
        </section>

        <!-- 3 -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-4">Sensitive Personal Information</h2>
          <div class="text-lumix-gray text-sm space-y-4">
            <p>
              We may process limited sensitive personal information such as authentication credentials and payment data.
              This information is used only to operate services, process payments, and prevent fraud.
            </p>

            <p>
              We do not use sensitive personal information to infer characteristics about users.
            </p>
          </div>
        </section>

        <!-- 4 -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-4">Sources of Information</h2>
          <ul class="text-lumix-gray text-sm list-disc list-inside ml-4 space-y-2">
            <li>Directly from you (account creation, purchases, support)</li>
            <li>Automatically via logs, cookies, and analytics</li>
            <li>Third parties (payment processors, fraud prevention tools)</li>
          </ul>
        </section>

        <!-- 5 -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-4">Purpose of Collection</h2>
          <ul class="text-lumix-gray text-sm list-disc list-inside ml-4 space-y-2">
            <li>Service delivery and hosting operations</li>
            <li>Security, fraud prevention, and abuse mitigation</li>
            <li>Billing and account management</li>
            <li>Service improvement and diagnostics</li>
            <li>Legal compliance</li>
          </ul>
        </section>

        <!-- 6 -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-4">Sharing of Information</h2>

          <div class="p-4 bg-lumix-red/10 border border-lumix-red/30 mb-4">
            <p class="text-lumix-white font-medium">
              We do not sell or share personal information as defined under the CCPA/CPRA.
            </p>
          </div>

          <ul class="text-lumix-gray text-sm list-disc list-inside ml-4 space-y-2">
            <li>Service providers (hosting, payments, support tools)</li>
            <li>Security and fraud prevention partners</li>
            <li>Legal authorities when required by law</li>
          </ul>
        </section>

        <!-- 7 -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-4">Financial Incentives</h2>
          <div class="text-lumix-gray text-sm">
            <p>
              We do not offer financial incentives, discounts, or pricing differences in exchange for personal information.
            </p>
          </div>
        </section>

        <!-- 8 -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-4">Your California Rights</h2>
          <ul class="text-lumix-gray text-sm list-disc list-inside ml-4 space-y-2">
            <li>Right to know what data is collected</li>
            <li>Right to delete personal information</li>
            <li>Right to correct inaccurate data</li>
            <li>Right to opt out of sale/sharing (not applicable)</li>
            <li>Right to limit use of sensitive data</li>
            <li>Right to non-discrimination</li>
          </ul>
        </section>

        <!-- 9 -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-4">Exercising Your Rights</h2>
          <div class="text-lumix-gray text-sm space-y-4">
            <p>You can submit requests via:</p>

            <div class="p-4 bg-lumix-black border border-terminal-border text-mono text-sm">
              Email: <a class="text-lumix-red" href={`mailto:${siteConfig.contact.email}`}>{siteConfig.contact.email}</a>
            </div>

            <p>
              We will verify your identity before processing requests and respond within 45 days.
            </p>
          </div>
        </section>

        <!-- 10 -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-4">Verification</h2>
          <div class="text-lumix-gray text-sm space-y-4">
            <p>
              We may require identity verification before fulfilling requests, including account confirmation or additional proof.
            </p>

            <p>
              Authorized agents must provide written permission or legal authorization.
            </p>
          </div>
        </section>

        <!-- 11 -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-4">Data Retention</h2>
          <div class="text-lumix-gray text-sm">
            <p>
              We retain data only as long as necessary for operational, legal, and security purposes.
            </p>

            <p class="mt-4 text-xs text-lumix-gray">
              Accounts: active + 30 days<br/>
              Billing: 7 years<br/>
              Logs: 90 days<br/>
              Support: 2 years
            </p>
          </div>
        </section>

        <!-- 12 -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-4">Shine the Light Law</h2>
          <div class="text-lumix-gray text-sm">
            <p>
              We do not share personal information with third parties for direct marketing purposes.
            </p>
          </div>
        </section>

        <!-- 13 -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-4">Changes to This Notice</h2>
          <div class="text-lumix-gray text-sm">
            <p>
              Updates will be posted on this page with a revised “Last updated” date.
            </p>
          </div>
        </section>

      </div>
    </div>
  </section>
</Layout>
