          </div>
        </div>
      </div>

      {videoEmbedUrl && (
    <div class="w-full bg-lumix-black-light border border-terminal-border p-4">
      <div class="flex items-center justify-between pb-3 mb-3 border-b border-terminal-border text-xs text-mono text-lumix-gray">
        <span class="flex items-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full bg-lumix-red animate-pulse"></span>
          SPOTLIGHT_FOOTAGE // SOURCE: YOUTUBE
        </span>
        <span class="text-lumix-gray-dark">STREAM_READY</span>
      </div>
      
      <div class="w-full aspect-video bg-black/80 border border-terminal-border/50 relative">
        <iframe 
          src={videoEmbedUrl} 
          title={`${spotlight.name} Showcase`}
          class="absolute inset-0 w-full h-full border-0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
          allowfullscreen
        ></iframe>
      </div>
    </div>
  )}

</div>
  </div>
</section>

  <!-- Community Evaluation & Culture Block -->
  <section class="pb-16 lg:pb-24 relative z-10">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          
          <div class="grid lg:grid-cols-2 gap-25 items-stretch">
            
            <div class="w-full h-full relative z-10">
                <Slideshow title="spotlight-viewer" images={spotlightImages} />
            </div>
            
            <div class="card p-6 bg-lumix-black-light border border-terminal-border h-full relative z-10">
              <span class="text-mono text-xs text-lumix-gray mb-4 block">// WHY_{spotlight.abbreviation}</span>
              <h3 class="text-lumix-white font-medium mb-4">Why {spotlight.name}?</h3>
              <div class="space-y-3 text-sm text-lumix-gray">
                {spotlight.ads.map((adTitle, index) => (
                  <div class="flex items-start gap-3">
                    <span class="text-lumix-red text-mono">0{index + 1}</span>
                    <div>
                      <span class="text-lumix-white">{adTitle}</span><br/>
                      {spotlight.adLong[index]}
                    </div>
                  </div>
                ))}
              </div>
            </div>

        </div>
      </div>
    </section>

<!-- Page Header (Moved to bottom of page for more attention to the server) --> 
<section class="py-16 lg:py-24 ">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <span class="text-mono text-xs text-lumix-gray mb-4 block animate-fade-in">
          <span class="text-lumix-red">$</span> cat /community/spotlight.conf
        </span>
        <h1 class="heading-xl text-lumix-white mb-6 animate-fade-in-up animate-delay-100">
          Server<br/>
          <span class="text-lumix-red">spotlight</span>
        </h1>
        <p class="body-lg text-lumix-gray animate-fade-in-up animate-delay-200">
          Each month, Lumix Solutions highlights a notable community-led server that demonstrates innovation, creativity, and dedication. These spotlights showcase the best of what the community has to offer and celebrate the hard work and dedication of server owners and developers.
        </p>
      </div>
    </div>
  </section>

  <!-- Divider -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center gap-4">
      <div class="flex-1 h-px bg-terminal-border"></div>
      <span class="text-mono text-xs text-lumix-gray-dark">END_PARTNERS // BEGIN_COLLABORATION</span>
      <div class="flex-1 h-px bg-terminal-border"></div>
    </div>
  </div>
  
  <!-- Partnership Inquiries Section -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20">
        <!-- Left: Info -->
        <div>
          <span class="text-mono text-xs text-lumix-gray mb-4 block">// PARTNERSHIP_INQUIRIES</span>
          <h2 class="heading-lg text-lumix-white mb-6">
            Partnership inquiries
          </h2>
          
          <div class="space-y-6">
            <p class="text-lumix-gray">
              Lumix Solutions partners with platforms, providers, and organizations that share a focus on reliability, security, and long-term infrastructure thinking.
            </p>
            <p class="text-lumix-gray">
              We are selective about partnerships and prioritize technical alignment over marketing arrangements.
            </p>
            
            <div class="mt-8">
              <h3 class="text-sm text-lumix-white font-medium mb-4">What we're open to</h3>
              <ul class="space-y-2">
                {openToPartnership.map(item => (
                  <li class="flex items-center gap-3 text-sm text-lumix-gray">
                    <span class="w-1 h-1 bg-lumix-red flex-shrink-0"></span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
        
        <!-- Right: Contact Block -->
        <div class="lg:sticky lg:top-24">
          <div class="p-6 bg-lumix-black-light border border-terminal-border">
            <span class="text-mono text-xs text-lumix-gray mb-4 block">// OPEN_CHANNEL</span>
            <h3 class="text-lumix-white font-medium mb-4">Contact</h3>
            <p class="text-sm text-lumix-gray mb-6">
              To discuss a potential partnership, reach out at:
            </p>
            
            <div class="space-y-3">
              <a 
                href="mailto:partners@lumixsolutions.org"
                class="flex items-center gap-2 text-mono text-sm text-lumix-red hover:underline"
              >
                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                </svg>
                partners@lumixsolutions.org
              </a>
              <a 
                href="mailto:contact@lumixsolutions.org"
                class="flex items-center gap-2 text-mono text-sm text-lumix-gray hover:text-lumix-red hover:underline transition-colors"
              >
                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                </svg>
                contact@lumixsolutions.org
              </a>
            </div>
            
            <div class="mt-6 pt-6 border-t border-terminal-border">
              <a 
                href="/contact"
                class="inline-flex items-center gap-2 text-sm text-lumix-gray hover:text-lumix-white transition-colors"
              >
                <span>Or visit our contact page</span>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>