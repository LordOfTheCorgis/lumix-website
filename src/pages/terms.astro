---
import Layout from "../layouts/Layout.astro";
import { siteConfig } from "../data/site";

const lastUpdated = "May 1, 2026";
---

<Layout
  title="Terms of Service"
  description="Terms of Service for Lumix Solutions - Hosting, VPS, and Game Server Infrastructure"
>
  <section class="py-16 lg:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Header -->
      <div class="mb-12">
        <span class="text-mono text-xs text-lumix-gray mb-4 block">
          <span class="text-lumix-red">$</span> cat /legal/terms.md
        </span>

        <h1 class="heading-xl text-lumix-white mb-4">
          Terms of <span class="text-lumix-red">Service</span>
        </h1>

        <p class="text-lumix-gray">
          Last updated: {lastUpdated}
        </p>
      </div>

      <div class="prose prose-invert max-w-none space-y-10">

        <!-- 1 -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-6">1. Agreement to Terms</h2>
          <div class="text-lumix-gray text-sm space-y-4">
            <p>
              By accessing or using Lumix Solutions (“we,” “us,” “our”), you agree to be legally bound by these Terms of Service.
              If you do not agree, you must immediately stop using all services.
            </p>

            <p>
              These Terms apply to all services including game servers, VPS hosting, dedicated servers, application hosting,
              storage, networking tools, and any related infrastructure provided by us.
            </p>
          </div>
        </section>

        <!-- 2 -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-6">2. Services</h2>
          <div class="text-lumix-gray text-sm space-y-4">
            <p>
              Lumix Solutions provides hosting infrastructure and related services including:
            </p>

            <ul class="list-disc list-inside ml-4 space-y-2">
              <li>Game server hosting (FiveM, RedM, Minecraft, modded environments)</li>
              <li>Virtual private servers (VPS)</li>
              <li>Dedicated server hosting</li>
              <li>Application hosting environments</li>
              <li>DDoS protection and network mitigation</li>
              <li>Control panels and management tools</li>
            </ul>

            <p>
              We may modify, suspend, or discontinue any service at any time for operational, security, or legal reasons.
            </p>
          </div>
        </section>

        <!-- 3 -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-6">3. Account Responsibility</h2>
          <div class="text-lumix-gray text-sm space-y-4">
            <ul class="list-disc list-inside ml-4 space-y-2">
              <li>You must provide accurate information during registration</li>
              <li>You are responsible for securing your credentials</li>
              <li>You are responsible for all actions under your account</li>
              <li>You must report unauthorized access immediately</li>
            </ul>

            <p>
              We may suspend accounts that are compromised or used in violation of these Terms.
            </p>
          </div>
        </section>

        <!-- 4 -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-6">4. Acceptable Use Policy</h2>
          <div class="text-lumix-gray text-sm space-y-6">

            <p class="font-medium text-lumix-white">
              The following uses are strictly prohibited:
            </p>

            <div>
              <h3 class="text-lumix-white font-medium">4.1 Illegal Activity</h3>
              <p>Any use that violates local, national, or international law.</p>
            </div>

            <div>
              <h3 class="text-lumix-white font-medium">4.2 Unauthorized or Pirated Content</h3>
              <p>
                Hosting cracked software, leaked game assets, stolen scripts, or unauthorized modifications including FiveM or Minecraft content.
              </p>
            </div>

            <div>
              <h3 class="text-lumix-white font-medium">4.3 Platform Violations</h3>
              <p>
                Violations of third-party terms including Cfx.re, Rockstar Games, Mojang/Microsoft, or any related platform policies.
              </p>
            </div>

            <div>
              <h3 class="text-lumix-white font-medium">4.4 Resource Abuse</h3>
              <p>
                Excessive or abusive use of CPU, RAM, storage, or bandwidth that impacts other users or system stability.
              </p>
            </div>

            <div>
              <h3 class="text-lumix-white font-medium">4.5 Network Abuse</h3>
              <p>
                DDoS attacks, scanning, exploitation attempts, or any malicious network behavior.
              </p>
            </div>

            <div>
              <h3 class="text-lumix-white font-medium">4.6 Harmful Content</h3>
              <p>
                Content involving exploitation, terrorism, violence, or illegal distribution of harmful material.
              </p>
            </div>

            <div>
              <h3 class="text-lumix-white font-medium">4.7 Cryptocurrency Mining (STRICTLY PROHIBITED)</h3>
              <p>
                Cryptocurrency mining of any kind is strictly prohibited across all services unless explicitly authorized in writing by Lumix Solutions.
              </p>

              <p class="mt-2 text-lumix-red font-medium">
                Violation will result in immediate suspension or permanent termination without refund.
              </p>
            </div>

          </div>
        </section>

        <!-- 5 -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-6">5. Billing & Payments</h2>
          <div class="text-lumix-gray text-sm space-y-4">
            <ul class="list-disc list-inside ml-4 space-y-2">
              <li>Services are billed in advance</li>
              <li>Failure to pay may result in suspension</li>
              <li>Extended non-payment may result in permanent termination</li>
              <li>Data may be deleted after termination</li>
            </ul>

            <p>
              Refunds are not guaranteed and are issued at our sole discretion unless required by law.
            </p>
          </div>
        </section>

        <!-- 6 -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-6">6. Service Availability</h2>
          <div class="text-lumix-gray text-sm space-y-4">
            <p>
              We aim to provide reliable infrastructure but do not guarantee uninterrupted service.
            </p>

            <ul class="list-disc list-inside ml-4 space-y-2">
              <li>Maintenance periods are excluded from uptime calculations</li>
              <li>External network failures are outside our control</li>
              <li>Service credits may be issued at our discretion</li>
            </ul>
          </div>
        </section>

        <!-- 7 -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-6">7. Data & Backups</h2>
          <div class="text-lumix-gray text-sm space-y-4">
            <p>
              You are solely responsible for maintaining backups of your data.
            </p>

            <p>
              We are not liable for any data loss under any circumstance, including hardware failure, misconfiguration, or termination.
            </p>
          </div>
        </section>

        <!-- 8 -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-6">8. Suspension & Termination</h2>
          <div class="text-lumix-gray text-sm space-y-4">
            <p>
              We may suspend or terminate services immediately if:
            </p>

            <ul class="list-disc list-inside ml-4 space-y-2">
              <li>These Terms are violated</li>
              <li>Abuse or malicious activity is detected</li>
              <li>Legal compliance requires removal of service</li>
            </ul>

            <p>
              Upon termination, access is revoked immediately and data may be permanently deleted.
            </p>
          </div>
        </section>

        <!-- 9 -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-6">9. Limitation of Liability</h2>
          <div class="text-lumix-gray text-sm space-y-4">
            <p>
              Services are provided “as is” without warranties of any kind.
            </p>

            <ul class="list-disc list-inside ml-4 space-y-2">
              <li>We are not liable for indirect or consequential damages</li>
              <li>Our liability is limited to the amount paid in the last 12 months</li>
              <li>We are not responsible for third-party outages or failures</li>
            </ul>
          </div>
        </section>

        <!-- 10 -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-6">10. Indemnification</h2>
          <div class="text-lumix-gray text-sm">
            <p>
              You agree to indemnify and hold harmless Lumix Solutions against any claims, damages, or costs arising from your use of the services or violation of these Terms.
            </p>
          </div>
        </section>

        <!-- 11 -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-6">11. Governing Law</h2>
          <div class="text-lumix-gray text-sm">
            <p>
              These Terms are governed by the laws of the United States. Disputes will be handled in a competent jurisdiction chosen by the Company.
            </p>
          </div>
        </section>

        <!-- 12 -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-6">12. Changes to Terms</h2>
          <div class="text-lumix-gray text-sm">
            <p>
              We may update these Terms at any time. Continued use of services constitutes acceptance of the updated Terms.
            </p>
          </div>
        </section>

        <!-- 13 -->
        <section class="card p-6 lg:p-8">
          <h2 class="heading-md text-lumix-white mb-6">13. Contact</h2>
          <div class="text-lumix-gray text-sm">
            <p>For questions regarding these Terms:</p>

            <div class="mt-4 p-4 bg-lumix-black border border-terminal-border text-mono text-sm">
              <span class="text-lumix-gray">Email:</span>
              <a href={`mailto:${siteConfig.contact.email}`} class="text-lumix-red">
                {siteConfig.contact.email}
              </a>
            </div>
          </div>
        </section>

      </div>
    </div>
  </section>
</Layout>
